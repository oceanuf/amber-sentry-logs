          {"name": "market_cap_coverage", "threshold": "≥80%", "weight": 0.2}
        ]
      },
      "precision_score": {
        "method": "阈值加权法",
        "logic": "跟踪误差、信息比率、年度胜率三个子维度加权求和",
        "sub_dimensions": [
          {"name": "tracking_error", "threshold": "≤0.5%", "weight": 0.4},
