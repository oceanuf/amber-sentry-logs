  "2_algorithm_transparency": {
    "tracking_deviation_calculation": {
      "method": "区间净值增长率之差",
      "python_logic": "tracking_error = abs(etf_return - benchmark_return)",
      "explanation": "使用ETF与基准指数在样本区间内的总收益率之差作为跟踪偏离度，而非日均涨跌幅之差。这种方法更能反映长期跟踪能力。",
      "implementation_code": "def calculate_tracking_error(etf_returns, benchmark_returns):\n    etf_total_return = (1 + etf_returns).prod() - 1\n    benchmark_total_return = (1 + benchmark_returns).prod() - 1\n    tracking_error = abs(etf_total_return - benchmark_total_return)\n    return tracking_error"
    },
    
    "correlation_calculation": {
      "method": "Pearson相关系数",
      "python_logic": "correlation = etf_returns.corr(benchmark_returns, method='pearson')",
      "explanation": "使用Pearson相关系数衡量ETF收益率与基准指数收益率的线性相关程度。Pearson相关系数适用于连续变量，能准确反映跟踪误差。",
      "implementation_code": "def calculate_correlation(etf_returns, benchmark_returns):\n    correlation = etf_returns.corr(benchmark_returns, method='pearson')\n    return correlation",
      "alternative_methods": {
        "spearman": "未使用，Spearman适用于等级相关或非线性关系",
        "kendall": "未使用，Kendall适用于小样本或有序数据"
      }
    },
    
    "dimension_score_calculation": {
      "skeleton_score": {
        "method": "阈值加权法",
        "logic": "每个子维度根据阈值判断得分，加权求和后归一化到0-100分",
        "sub_dimensions": [
          {"name": "top10_concentration", "threshold": "≥60%", "weight": 0.3},
