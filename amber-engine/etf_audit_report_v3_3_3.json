        ]
      },
      "liquidity_score": {
        "method": "分段函数法",
        "logic": "根据日均成交额分段赋予不同得分",
        "segments": [
          {"condition": "fund_size ≥ 5亿", "score": "40/40"},
          {"condition": "avg_daily_volume ≥ 1亿", "score": "35/35"},
          {"condition": "bid_ask_spread ≤ 0.1%", "score": "25/25"}
        ]
      },
      "cost_score": {
        "method": "反比例函数法",
        "logic": "费率越低得分越高，超过阈值得分大幅降低",
        "formula": "score = max(0, (0.006 / total_fee) * 50) + 管理费得分 + 趋势得分"
