# 档案馆单体仓库同步法典 V3.1 (修正版) - 安全忽略规则
# 生效日期: 2026-03-30 (第14周)
# 基于[2614-001]安全防线协议

# 1. 环境配置文件 (绝对禁止泄露) - 三不原则第一防线
.env
.env.*
*.env
secrets/
credentials/
private_*.json
config_*.json
token.json
secrets.json
credentials.json

# 2. Token敏感文件 (ghp_开头) - 三不原则第二防线
*ghp_*
*github_pat*
*access_token*
*api_key*

# 3. 绝对路径敏感文件 - 三不原则第三防线
*绝对路径*
*home/luckyelite*
*/home/*

# 4. 数据库文件 (本地开发环境)
*.db
*.sqlite
*.sqlite3
database/*.db
_PRIVATE_DATA/

# 5. 日志文件
*.log
**/*.log
logs/
amber-sentry-logs/
pulse_monitor.log
audit_log.txt

# 6. 备份文件
*.backup
*.bak
backup/
backup_*/
backup_monorepo_*/
backup_absolute_paths_*

# 7. 虚拟环境和缓存
venv/
__pycache__/
*.pyc
.pytest_cache/
node_modules/

# 8. 临时文件
*.tmp
*.temp
.tmp/
*.swp
*.swo

# 9. 系统文件
.DS_Store
Thumbs.db

# 10. 本地开发文件 (根据物理拓扑准则)
portfolio_v1.json
portfolio_v1.html
output/arena/  # 演武场输出目录
output/  # 临时输出目录
nginx/  # Nginx配置文件 (敏感)
.openclaw/  # OpenClaw配置 (敏感)
master-audit/  # Web部署目录 (可能包含敏感配置)
data/algo_log/  # 算法日志 (临时数据)
health_reports/  # 健康报告 (已并入docs/reports/)
lib/  # 库文件 (应并入scripts/lib/或web/)
templates/  # 模板文件 (应并入web/templates/)
static/  # 静态资源 (应并入web/static/)

# 11. 根目录杂文件 (应移动到相应目录)
# 以下文件类型应移动到法典规定的目录:
# - *.md → docs/reports/ 或 vaults/
# - *.txt → docs/reports/
# - *.json → database/ (仅结构定义)
# - *.sh, *.py → scripts/
# - *.html, *.php, *.js, *.css → web/