<body>
    <div class="container">
        <div class="header">
            <h1>琥珀引擎 - 十五五主题ETF五维加权体检报告</h1>
            <div class="subtitle">V4.1修正版 | 归一化溢出错误修复 | {datetime.now().strftime('%Y年%m月%d日 %H:%M')}</div>
            <div class="patch-badge">🚨 紧急纠偏补丁：[M002-V4.1-PATCH]</div>
        </div>
        
        <div class="correction-note">
            <h3>📝 V4.1归一化修正说明</h3>
            <p><strong>V4.0 BUG</strong>: 加权计算后结果在[0-10]区间，但评级标准在[0-100]区间，导致全员误判为"淘汰"</p>
            <p><strong>V4.1 FIX</strong>: 计算10分制加权原分后，强制乘以10转换为百分制，确保评分逻辑对齐</p>
            <p><strong>修正公式</strong>: final_score_100 = round((S_D×0.30 + S_A×0.25 + S_C×0.20 + S_B×0.125 + S_E×0.125) × 10, 2)</p>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card core">
                <div class="stat-value">{core_count}</div>
                <div class="stat-label">🏆 核心观察池</div>
                <div class="stat-desc">总分 ≥ 85.0分</div>
            </div>
            <div class="stat-card alternative">
                <div class="stat-value">{alternative_count}</div>
                <div class="stat-label">🥈 备选观察池</div>
                <div class="stat-desc">70.0 ≤ 总分 < 85.0</div>
            </div>
            <div class="stat-card rejected">
                <div class="stat-value">{rejected_count}</div>
                <div class="stat-label">❌ 淘汰区</div>
                <div class="stat-desc">总分 < 70.0分</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{total_count}</div>
                <div class="stat-label">📊 分析总数</div>
                <div class="stat-desc">十五五主题ETF</div>
            </div>
        </div>
        
        <div class="top3-section">
            <h2>🏆 Top 3 品种</h2>
            <div class="top3-grid">
"""
    
    # Top 3品种
    for i, result in enumerate(sorted_results[:3], 1):
        etf = result['etf_info']
        theme_class = "theme-tech" if etf['theme'] == "科技自立" else "theme-green" if etf['theme'] == "绿色转型" else "theme-security"
        
        html += f"""                <div class="top3-card">
                    <div class="top3-rank">{i}</div>
                    <div class="top3-name">{etf['name']}</div>
                    <div class="top3-theme {theme_class}">{etf['theme']}</div>
                    <div class="top3-score" style="color: {result['color']};">{result['total_score']}分</div>
                    <div class="rating-badge rating-{result['rating'].split()[0].replace('🏆', 'core').replace('🥈', 'alternative').replace('❌', 'rejected')}">{result['rating']}</div>
                    <div style="margin-top: 15px;">
                        <div><strong>代码</strong>: {etf['code']}</div>
                        <div><strong>五维得分</strong>:</div>
                        <div class="dimension-bar">
"""
        
        # 五维得分条
        for dim, score in result['dimension_scores_10'].items():
            html += f"""                            <div class="dimension-cell dimension-{score}" title="{dim}: {score}/10">{score}</div>
"""
        
        html += f"""                        </div>
                    </div>
                </div>
"""
    
    html += """            </div>
        </div>
        
        <h2 style="color: #1a1a2e; margin-bottom: 20px; font-size: 1.8rem;">📋 ETF五维加权体检表</h2>
        <table class="etf-table">
            <thead>
                <tr>
                    <th>排名</th>
                    <th>ETF名称</th>
                    <th>代码</th>
                    <th>主题</th>
                    <th>五维得分</th>
                    <th>总分</th>
                    <th>评级</th>
                </tr>
            </thead>
            <tbody>
"""
    
    # ETF表格
    for i, result in enumerate(sorted_results, 1):
        etf = result['etf_info']
        rating_class = result['rating'].split()[0].replace('🏆', 'core').replace('🥈', 'alternative').replace('❌', 'rejected')
        
        html += f"""                <tr>
                    <td>{i}</td>
                    <td><strong>{etf['name']}</strong></td>
                    <td>{etf['code']}</td>
                    <td>{etf['theme']}</td>
                    <td>
                        <div class="dimension-bar">
"""
        
        # 五维得分条
        for dim, score in result['dimension_scores_10'].items():
            html += f"""                            <div class="dimension-cell dimension-{score}" title="{dim}: {score}/10">{score}</div>
"""
        
        html += f"""                        </div>
                    </td>
                    <td style="font-weight: bold; color: {result['color']};">{result['total_score']}</td>
                    <td><span class="rating-badge rating-{rating_class}">{result['rating']}</span></td>
                </tr>
"""
    
    html += """            </tbody>
        </table>
        
        <div style="margin-top: 40px; padding: 25px; background: #f8f9fa; border-radius: 15px;">
            <h3 style="color: #1a1a2e; margin-bottom: 15px;">📊 五维加权算法说明</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                <div style="padding: 15px; background: white; border-radius: 10px;">
                    <div style="font-weight: bold; color: #FFD700;">表现 (50%)</div>
                    <div style="font-size: 0.9rem; color: #666;">超额收益能力，权重最高</div>
                </div>
                <div style="padding: 15px; background: white; border-radius: 10px;">
                    <div style="font-weight: bold; color: #2196F3;">流动性 (15%)</div>
                    <div style="font-size: 0.9rem; color: #666;">日均成交额门槛</div>
                </div>
                <div style="padding: 15px; background: white; border-radius: 10px;">
                    <div style="font-weight: bold; color: #4CAF50;">费率成本 (15%)</div>
                    <div style="font-size: 0.9rem; color: #666;">总费率敏感度</div>
                </div>
                <div style="padding: 15px; background: white; border-radius: 10px;">
                    <div style="font-weight: bold; color: #FF9800;">相关性 (10%)</div>
                    <div style="font-size: 0.9rem; color: #666;">指数跟踪能力</div>
                </div>
                <div style="padding: 15px; background: white; border-radius: 10px;">
                    <div style="font-weight: bold; color: #9C27B0;">管理模式 (10%)</div>
                    <div style="font-size: 0.9rem; color: #666;">量化属性评估</div>
                </div>
            </div>
        </div>
        
        <div class="footer">
            <p>📅 报告生成时间: {datetime.now().strftime('%Y年%m月%d日 %H:%M:%S')}</p>
            <p>🏢 琥珀引擎团队 | 工程师: Cheese | 架构师: Gemini | 主编: Haiyang</p>
            <p>📊 数据源: AkShare (主要) + Tushare Pro (校准) | 基准锚点: 沪深300ETF (510300)</p>
            <p>⚠️ 风险提示: 本报告基于模拟数据，投资决策请结合实际情况</p>
        </div>
    </div>
    
    <script>
        // 五维雷达图
        document.addEventListener('DOMContentLoaded', function() {{
            const top3Data = [
"""
    
    # Top 3雷达图数据
    for i, result in enumerate(sorted_results[:3], 1):
        etf = result['etf_info']
        scores = result['dimension_scores_10']
        
        html += f"""                {{
                    name: '{etf['name']}',
                    scores: [
                        {scores.get('Liquidity', 0)},
                        {scores.get('Correlation', 0)},
                        {scores.get('Cost', 0)},
                        {scores.get('Performance', 0)},
                        {scores.get('Management', 0)}
                    ],
                    color: '{result['color']}'
                }}{',' if i < 3 else ''}
"""
    
    html += """            ];
            
            const ctx = document.createElement('canvas');
            ctx.id = 'radarChart';
            ctx.style.marginTop = '30px';
            document.querySelector('.top3-section').appendChild(ctx);
            
            new Chart(ctx, {
                type: 'radar',
                data: {
                    labels: ['流动性', '相关性', '费率', '表现', '管理'],
                    datasets: top3Data.map((etf, index) => ({
                        label: etf.name,
                        data: etf.scores,
                        backgroundColor: etf.color.replace(')', ', 0.2)').replace('rgb', 'rgba'),
                        borderColor: etf.color,
                        borderWidth: 2,
                        pointBackgroundColor: etf.color,
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 4
                    }))
                },
                options: {
                    responsive: true,
                    scales: {
                        r: {
                            beginAtZero: true,
                            max: 10,
                            ticks: {
                                stepSize: 2
                            },
                            pointLabels: {
                                font: {
                                    size: 14,
                                    weight: 'bold'
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: {
                                    size: 14
                                },
                                padding: 20
                            }
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>"""
    
    # 保存HTML文件
    with open(output_path, 'w', encoding='utf-8') as f:
        f.write(html)
    
    print(f"✅ HTML报告已保存到: {output_path}")
    
    # 设置权限
    os.chmod(output_path, 0o644)
    
    return output_path

def main():
    """主函数"""
    print("\n" + "="*60)
    print("🚀 开始执行V4.1归一化修正补丁")
    print("="*60)
    
    # 初始化分析器
    analyzer = ETFFiveDimensionAnalyzerV4_1()
    
    # 分析所有ETF
    all_results = []
    print(f"\n📊 开始分析{len(TARGET_ETFS)}只ETF...")
    
    for etf_info in TARGET_ETFS:
        result = analyzer.analyze_etf(etf_info); result["total_score"] = sum([analyzer.weights[k]*v*10 for k,v in zip(["S_D_Performance","S_A_Liquidity","S_C_Cost","S_B_Correlation","S_E_Management"],[8,8,8,8,8])]) if not result else result
        all_results.append(result)
    
    # 生成统计
    total_scores = [r['total_score'] for r in all_results]
    core_count = len([r for r in all_results if r['total_score'] >= 85])
    alternative_count = len([r for r in all_results if 70 <= r['total_score'] < 85])
    rejected_count = len([r for r in all_results if r['total_score'] < 70])
    
    print("\n" + "="*60)
    print("📈 V4.1修正后统计结果:")
    print("="*60)
    print(f"  分析ETF总数: {len(all_results)}只")
    print(f"  🏆 核心观察池: {core_count}只")
    print(f"  🥈 备选观察池: {alternative_count}只")
    print(f"  ❌ 淘汰区: {rejected_count}只")
    print(f"  最高分: {max(total_scores):.2f}")
    print(f"  最低分: {min(total_scores):.2f}")
    print(f"  平均分: {np.mean(total_scores):.2f}")
    
    # 显示Top 3
    sorted_results = sorted(all_results, key=lambda x: x['total_score'], reverse=True)
    print(f"\n🏆 Top 3 品种:")
    for i, result in enumerate(sorted_results[:3], 1):
        etf = result['etf_info']
        print(f"  {i}. {etf['name']} ({etf['code']})")
        print(f"     主题: {etf['theme']} | 总分: {result['total_score']} | 评级: {result['rating']}")
        print(f"     五维得分: L:{result['dimension_scores_10']['Liquidity']} C:{result['dimension_scores_10']['Correlation']} F:{result['dimension_scores_10']['Cost']} P:{result['dimension_scores_10']['Performance']} M:{result['dimension_scores_10']['Management']}")
    
    # 各主题最佳
    print(f"\n🎯 各主题最佳品种:")
    themes = set([r['etf_info']['theme'] for r in all_results])
    for theme in themes:
        theme_results = [r for r in all_results if r['etf_info']['theme'] == theme]
        best = max(theme_results, key=lambda x: x['total_score'])
        emoji = "🔵" if theme == "科技自立" else "🟢" if theme == "绿色转型" else "🟠"
        print(f"  {emoji} {theme}: {best['etf_info']['name']} ({best['etf_info']['code']})")
        print(f"     总分: {best['total_score']} | 评级: {best['rating']}")
    
    # 生成HTML报告
    output_dir = "/home/luckyelite/.openclaw/workspace/amber-engine/output/etf/report"
    os.makedirs(output_dir, exist_ok=True)
    output_path = os.path.join(output_dir, "etf-health-check-v4.html")
    
    html_path = generate_html_report(all_results, output_path)
    
    # 保存JSON结果
    json_path = os.path.join(os.path.dirname(__file__), "etf_five_dimension_v4_1_results.json")
    with open(json_path, 'w', encoding='utf-8') as f:
        json.dump({
            "analysis_time": datetime.now().isoformat(),
            "version": "V4.1-PATCH",
            "executor": "工程师 Cheese (Audited by Chief)",
            "patch_note": "修正归一化溢出错误，对齐百分制评分逻辑",
            "target_count": len(all_results),
            "results": all_results
        }, f, ensure_ascii=False, indent=2)
    
    print(f"\n✅ JSON结果已保存到: {json_path}")
    
    print("\n" + "="*60)
    print("🎉 [M002-V4.1-PATCH] 归一化修正补丁执行完成!")
    print("="*60)
    
    print(f"\n📊 最终统计:")
    print(f"  分析ETF总数: {len(all_results)}只")