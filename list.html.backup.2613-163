</html>
   // 实战看板控制函数
   let refreshTimer;
   let counter = 30;
   
   function refreshDashboard() {
     const frame = document.getElementById('portfolioFrame');
     frame.src = frame.src; // 重新加载
     counter = 30;
     document.getElementById('refreshCounter').textContent = counter;
     resetTimer();
   }
   
   function toggleFullscreen() {
     const frame = document.getElementById('portfolioFrame');
     if (!document.fullscreenElement) {
       if (frame.requestFullscreen) {
         frame.requestFullscreen();
       }
     } else {
       if (document.exitFullscreen) {
         document.exitFullscreen();
       }
     }
   }
   
   function resetTimer() {
     clearInterval(refreshTimer);
     refreshTimer = setInterval(() => {
       counter--;
       document.getElementById('refreshCounter').textContent = counter;
       if (counter <= 0) {
         refreshDashboard();
       }
     }, 1000);
   }
   
   // 初始启动定时器
   document.addEventListener('DOMContentLoaded', function() {
     resetTimer();
     
     // 更新状态指示器
     setTimeout(() => {
       const statusIndicator = document.querySelector('.status-indicator');
       if (statusIndicator) {
         statusIndicator.innerHTML = '✅ 实时数据流已连接 | 看板加载完成';
         statusIndicator.style.background = 'rgba(40, 167, 69, 0.1)';
         statusIndicator.style.color = '#28a745';
       }
     }, 1000);
   });
