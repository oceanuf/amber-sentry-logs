   padding: 4px 12px;
   border-radius: 20px;
   font-size: 14px;
   font-weight: 600;
 }
 
 /* 中部 - 127号Alpha报告 */
 .alpha-section {
   background: white;
   padding: 25px;
   border-radius: 12px;
   margin-bottom: 25px;
   box-shadow: 0 2px 8px rgba(0,0,0,0.08);
   border-left: 5px solid #28a745;
 }
 
 .alpha-section h2 {
   color: #28a745;
   margin-top: 0;
   display: flex;
   align-items: center;
   gap: 10px;
 }
 
 .alpha-grid {
   display: grid;
   grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
   gap: 20px;
   margin-top: 20px;
 }
 
 .alpha-card {
   background: #f8f9fa;
   padding: 20px;
   border-radius: 8px;
   border: 1px solid #e9ecef;
 }
 
 .alpha-card h3 {
   margin-top: 0;
   color: #495057;
   font-size: 18px;
 }
 
 .alpha-rank {
   font-size: 24px;
   font-weight: bold;
   color: #1a2980;
   margin-bottom: 10px;
 }
 
 /* 实战看板预留区域 */
